# Ignore everything by default
*

# Allow gitignore itself
!.gitignore

# Go source code
!*.go
!go.mod
!go.sum

# Allow directories (needed for recursive whitelisting)
!*/

# Documentation
!*.md
!CLAUDE.md
!LICENSE
!Makefile

# Test data
!testdata/
!testdata/**

# Example scripts
!examples/
!examples/**
!*.sh

# Configuration
# template_index.json is generated by buildTemplateIndex and excluded from public repo

# MCP server
!mcp-server/
!mcp-server/main.go

# ---- Explicit excludes (override the whitelist above) ----

# Generated template data
template/

# Compiled binaries
bin/
main
analyzeSlides/analyze_slides
extractPDF/extract_pdf

# Secrets and environment
.envrc
*.credentials*
*.json.backup

# Claude local settings
.claude/

# Images (generated slides)
*.png
*.jpg
*.jpeg

# Allow docs diagrams
!docs/*.puml
!docs/*.png
!docs/*.svg

# OS files
.DS_Store
